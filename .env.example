# App
PORT=3000
JWT_SECRET=change_this_secret

# MySQL target (used by app and migration target)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=Chordsmith Studio
DB_CONNECTION_LIMIT=10

# Optional SQL Server source (only used by scripts/migrate-sqlserver-to-mysql.js)
SRC_MSSQL_SERVER=localhost
SRC_MSSQL_PORT=1433
SRC_MSSQL_DATABASE=ChordSmith
SRC_MSSQL_USER=sa
SRC_MSSQL_PASSWORD=change_me
SRC_MSSQL_ENCRYPT=false
SRC_MSSQL_TRUST_CERT=true

# Email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=user@example.com
EMAIL_PASS=change_me
EMAIL_FROM="ChordSmith <user@example.com>"
